generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ============================
// Better Auth Models
// ============================

model session {
  id                   String   @id
  expiresAt            DateTime
  token                String   @unique
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  ipAddress            String?
  userAgent            String?
  userId               String   @db.Uuid
  user                 users    @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeOrganizationId String?

  @@map("session")
}

model account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String    @db.Uuid
  user                  users     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

model organization {
  id                       String   @id
  name                     String
  slug                     String?  @unique
  logo                     String?
  description              String?
  createdBy                String?  @map("created_by")
  createdAt                DateTime @default(now())
  metadata                 String?
  appId                    String?  @unique @db.Uuid
  aiCredits                Decimal? @default(0.0) @map("ai_credits") @db.Decimal(10, 2)
  aiCreditWarningThreshold Decimal? @default(5.0) @map("ai_credit_warning_threshold") @db.Decimal(10, 2)
  aiLowCreditAlertSent     Boolean? @default(false) @map("ai_low_credit_alert_sent")

  members            member[]
  invitations        invitation[]
  app                apps?                 @relation(fields: [appId], references: [id])
  creditTransactions credit_transactions[]

  @@map("organization")
}

model member {
  id             String       @id
  organizationId String
  organization   organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String       @db.Uuid
  user           users        @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String       @default("member")
  createdAt      DateTime     @default(now())

  @@map("member")
}

model invitation {
  id             String       @id
  organizationId String
  organization   organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String?
  status         String       @default("pending")
  expiresAt      DateTime
  inviterId      String       @db.Uuid
  inviter        users        @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@map("invitation")
}

model accounts {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String             @db.VarChar(255)
  created_at       DateTime?          @default(now()) @db.Timestamp(6)
  automation_rules automation_rules[]
  broadcasts       broadcasts[]
  canned_responses canned_responses[]
  contacts         contacts[]
  conversations    conversations[]
  inboxes          inboxes[]
  labels           labels[]
  teams            teams[]
  webhooks         webhooks[]
}

model agent_availability {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id               String
  app_id                String    @db.Uuid
  is_available          Boolean?  @default(true)
  max_conversations     Int?      @default(5)
  current_conversations Int?      @default(0)
  skills                String[]  @default([])
  languages             String[]  @default(["en"])
  last_assigned_at      DateTime? @db.Timestamptz(6)
  updated_at            DateTime? @default(now()) @db.Timestamptz(6)
  apps                  apps      @relation(fields: [app_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, app_id])
  @@index([app_id, is_available], map: "idx_agent_availability_app")
}

model agent_channel_accounts {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String
  channel_type     String           @db.VarChar(50)
  account_id       String           @db.Uuid
  created_at       DateTime?        @default(now()) @db.Timestamp(6)
  channel_accounts channel_accounts @relation(fields: [account_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, account_id])
  @@index([account_id], map: "idx_agent_channel_accounts_account")
  @@index([user_id], map: "idx_agent_channel_accounts_user")
}

model agent_channels {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String    @db.Uuid
  channel_type String    @db.VarChar(50)
  created_at   DateTime? @default(now()) @db.Timestamp(6)

  @@unique([user_id, channel_type])
  @@index([channel_type], map: "idx_agent_channels_type")
  @@index([user_id], map: "idx_agent_channels_user")
}

model agent_divisions {
  user_id     String    @db.Uuid
  division_id String    @db.Uuid
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  divisions   divisions @relation(fields: [division_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([user_id, division_id])
  @@index([division_id], map: "idx_agent_divisions_division")
  @@index([user_id], map: "idx_agent_divisions_user")
}

model agent_inbox_assignments {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String?   @db.Uuid
  inbox_id    String?   @db.Uuid
  is_active   Boolean?  @default(true)
  assigned_at DateTime? @default(now()) @db.Timestamp(6)
  assigned_by String?   @db.Uuid

  @@unique([user_id, inbox_id])
  @@index([is_active], map: "idx_agent_inbox_active")
  @@index([inbox_id], map: "idx_agent_inbox_inbox")
  @@index([user_id], map: "idx_agent_inbox_user")
}

model agent_presence {
  user_id      String    @id @db.Uuid
  status       String?   @default("offline") @db.VarChar(20)
  last_seen_at DateTime? @default(now()) @db.Timestamp(6)
}

model agent_settings {
  id                                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  app_id                                String    @unique @db.Uuid
  default_ticket_board_id               String?   @db.Uuid
  auto_assign_agent                     Boolean?  @default(false)
  agent_can_takeover_unserved           Boolean?  @default(true)
  agent_can_access_customers            Boolean?  @default(true)
  agent_can_import_export_customers     Boolean?  @default(false)
  agent_can_send_broadcast              Boolean?  @default(true)
  agent_can_broadcast_in_service_window Boolean?  @default(false)
  hide_agent_status_toggle              Boolean?  @default(false)
  hide_customer_id                      Boolean?  @default(false)
  agent_can_assign_chat                 Boolean?  @default(true)
  agent_can_add_agents_to_chat          Boolean?  @default(true)
  agent_can_leave_chat                  Boolean?  @default(true)
  hide_handover_dialogue                Boolean?  @default(true)
  agent_can_manage_quick_replies        Boolean?  @default(true)
  created_at                            DateTime? @default(now()) @db.Timestamp(6)
  updated_at                            DateTime? @default(now()) @db.Timestamp(6)
  apps                                  apps      @relation(fields: [app_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([app_id], map: "idx_agent_settings_app_id")
}

model agent_settings_overrides {
  id                                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                               String    @unique @db.Uuid
  auto_assign_agent                     Boolean?
  agent_can_takeover_unserved           Boolean?
  agent_can_access_customers            Boolean?
  agent_can_import_export_customers     Boolean?
  agent_can_send_broadcast              Boolean?
  agent_can_broadcast_in_service_window Boolean?
  hide_agent_status_toggle              Boolean?
  hide_customer_id                      Boolean?
  agent_can_assign_chat                 Boolean?
  agent_can_add_agents_to_chat          Boolean?
  agent_can_leave_chat                  Boolean?
  hide_handover_dialogue                Boolean?
  agent_can_manage_quick_replies        Boolean?
  updated_at                            DateTime? @default(now()) @db.Timestamp(6)

  @@index([user_id], map: "idx_agent_settings_overrides_user_id")
}

model ai_conversation_contexts {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversation_id   String    @unique @db.Uuid
  context_summary   String?
  entities          Json?     @default("{}")
  ai_reply_count    Int?      @default(0)
  last_ai_action    String?   @db.VarChar(50)
  last_ai_action_at DateTime? @db.Timestamptz(6)
  human_takeover    Boolean?  @default(false)
  human_takeover_at DateTime? @db.Timestamptz(6)
  updated_at        DateTime? @default(now()) @db.Timestamptz(6)

  @@index([conversation_id], map: "idx_ai_contexts_conversation")
}

model ai_evaluation_messages {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  evaluation_id   String         @db.Uuid
  role            String         @db.VarChar(20)
  message         String
  msg_id          String?        @db.VarChar(255)
  media_url       String?
  media_type      String?        @default("text") @db.VarChar(50)
  conversation_id String?        @db.Uuid
  msg_created_at  DateTime?      @db.Timestamptz(6)
  created_at      DateTime?      @default(now()) @db.Timestamptz(6)
  ai_evaluations  ai_evaluations @relation(fields: [evaluation_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([evaluation_id], map: "idx_ai_eval_messages_eval")
}

model ai_evaluations {
  id                     String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  app_id                 String                   @db.Uuid
  chatbot_id             String                   @db.Uuid
  content                String?
  type                   String?                  @default("evaluation") @db.VarChar(50)
  metadata               Json?                    @default("{}")
  created_at             DateTime?                @default(now()) @db.Timestamptz(6)
  updated_at             DateTime?                @default(now()) @db.Timestamptz(6)
  deleted_at             DateTime?                @db.Timestamptz(6)
  ai_evaluation_messages ai_evaluation_messages[]
  apps                   apps                     @relation(fields: [app_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  chatbots               chatbots                 @relation(fields: [chatbot_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([app_id], map: "idx_ai_evaluations_app")
  @@index([chatbot_id], map: "idx_ai_evaluations_chatbot")
}

model ai_response_templates {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  app_id      String    @db.Uuid
  name        String    @db.VarChar(255)
  template    String
  variables   Json?     @default("[]")
  category    String?   @db.VarChar(100)
  language    String?   @default("en") @db.VarChar(10)
  is_active   Boolean?  @default(true)
  usage_count Int?      @default(0)
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  updated_at  DateTime? @default(now()) @db.Timestamptz(6)
  apps        apps      @relation(fields: [app_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model ai_settings {
  id                              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  app_id                          String    @unique @db.Uuid
  ai_mode                         String?   @default("assist") @db.VarChar(50)
  model_provider                  String?   @default("openai") @db.VarChar(50)
  model_name                      String?   @default("gpt-4o-mini") @db.VarChar(100)
  temperature                     Decimal?  @default(0.7) @db.Decimal(2, 1)
  max_tokens                      Int?      @default(500)
  auto_reply_confidence           Decimal?  @default(0.85) @db.Decimal(3, 2)
  handoff_keywords                String[]  @default(["speak to human", "talk to agent", "help"])
  response_tone                   String?   @default("professional") @db.VarChar(50)
  supported_languages             String[]  @default(["en", "id"])
  auto_detect_language            Boolean?  @default(true)
  max_ai_replies_per_conversation Int?      @default(5)
  cooldown_after_limit_minutes    Int?      @default(30)
  created_at                      DateTime? @default(now()) @db.Timestamptz(6)
  updated_at                      DateTime? @default(now()) @db.Timestamptz(6)
  use_platform_credentials        Boolean?  @default(false)
  api_key                         String?
  api_endpoint                    String?
  api_version                     String?   @default("2024-02-15-preview") @db.VarChar(50)
  deployment_name                 String?   @db.VarChar(255)
  apps                            apps      @relation(fields: [app_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model ai_model_pricing {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  model_name       String    @unique @db.VarChar(100)
  cost_per_request Decimal   @db.Decimal(10, 4)
  description      String?
  is_active        Boolean?  @default(true)
  updated_at       DateTime? @default(now()) @db.Timestamptz(6)

  @@index([model_name], map: "idx_ai_model_pricing_name")
  @@index([is_active], map: "idx_ai_model_pricing_is_active")
}

model ai_response_logs {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  app_id                String    @db.Uuid
  chatbot_id            String    @db.Uuid
  conversation_id       String?   @db.Uuid
  entrypoint            String    @db.VarChar(60)
  provider              String?   @db.VarChar(80)
  model_name            String?   @db.VarChar(200)
  prompt_tokens         Int?      @default(0)
  completion_tokens     Int?      @default(0)
  total_tokens          Int?      @default(0)
  usage_credits         Decimal?  @default(0) @db.Decimal(18, 6)
  usage_usd             Decimal?  @default(0) @db.Decimal(18, 6)
  usage_idr             Decimal?  @default(0) @db.Decimal(18, 6)
  billed_credits        Decimal?  @default(0) @db.Decimal(18, 6)
  knowledge_references  Json?     @default("[]")
  rtk_summary           Json?     @default("{}")
  message_ids           String[]  @default([])
  status                String?   @default("generated") @db.VarChar(50)
  retry_count           Int?      @default(0)
  knowledge_snapshot_at DateTime? @db.Timestamptz(6)
  created_at            DateTime? @default(now()) @db.Timestamptz(6)
  updated_at            DateTime? @default(now()) @db.Timestamptz(6)

  @@index([app_id], map: "idx_ai_response_logs_app")
  @@index([chatbot_id], map: "idx_ai_response_logs_chatbot")
  @@index([conversation_id], map: "idx_ai_response_logs_conversation")
  @@index([entrypoint], map: "idx_ai_response_logs_entrypoint")
  @@index([created_at], map: "idx_ai_response_logs_created")
}

model ai_playground_models {
  id                   String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  app_id               String                   @db.Uuid
  model_key            String                   @db.VarChar(80)
  name                 String                   @db.VarChar(160)
  vendor               String                   @db.VarChar(120)
  context_window       String                   @db.VarChar(32)
  price_in             Decimal                  @db.Decimal(12, 6)
  price_out            Decimal                  @db.Decimal(12, 6)
  speed                String                   @db.VarChar(20)
  tier                 String                   @db.VarChar(20)
  connected            Boolean?                 @default(false)
  latency_ms           Int?
  usage_percent        Int?                     @default(0)
  sort_order           Int?                     @default(0)
  created_at           DateTime?                @default(now()) @db.Timestamptz(6)
  updated_at           DateTime?                @default(now()) @db.Timestamptz(6)
  apps                 apps                     @relation(fields: [app_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  selected_in_sessions ai_playground_sessions[] @relation("playground_selected_model")

  @@unique([app_id, model_key], map: "uq_ai_playground_models_app_key")
  @@index([app_id, sort_order], map: "idx_ai_playground_models_app_sort")
  @@index([app_id, connected], map: "idx_ai_playground_models_app_connected")
}

model ai_playground_routing_strategies {
  id                   String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  app_id               String                   @db.Uuid
  strategy_key         String                   @db.VarChar(80)
  label                String                   @db.VarChar(120)
  description          String
  routing_rules        Json                     @default("[]")
  is_active            Boolean?                 @default(false)
  sort_order           Int?                     @default(0)
  created_at           DateTime?                @default(now()) @db.Timestamptz(6)
  updated_at           DateTime?                @default(now()) @db.Timestamptz(6)
  apps                 apps                     @relation(fields: [app_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  selected_in_sessions ai_playground_sessions[] @relation("playground_selected_strategy")

  @@unique([app_id, strategy_key], map: "uq_ai_playground_routing_app_key")
  @@index([app_id, sort_order], map: "idx_ai_playground_routing_app_sort")
  @@index([app_id, is_active], map: "idx_ai_playground_routing_app_active")
}

model ai_playground_personas {
  id                   String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  app_id               String                   @db.Uuid
  persona_key          String                   @db.VarChar(80)
  label                String                   @db.VarChar(160)
  system_instruction   String
  is_default           Boolean?                 @default(false)
  sort_order           Int?                     @default(0)
  created_at           DateTime?                @default(now()) @db.Timestamptz(6)
  updated_at           DateTime?                @default(now()) @db.Timestamptz(6)
  apps                 apps                     @relation(fields: [app_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  selected_in_sessions ai_playground_sessions[] @relation("playground_selected_persona")

  @@unique([app_id, persona_key], map: "uq_ai_playground_personas_app_key")
  @@index([app_id, sort_order], map: "idx_ai_playground_personas_app_sort")
  @@index([app_id, is_default], map: "idx_ai_playground_personas_app_default")
}

model ai_playground_guardrails {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  app_id        String    @db.Uuid
  guardrail_key String    @db.VarChar(80)
  label         String    @db.VarChar(180)
  enabled       Boolean?  @default(true)
  sort_order    Int?      @default(0)
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
  updated_at    DateTime? @default(now()) @db.Timestamptz(6)
  apps          apps      @relation(fields: [app_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([app_id, guardrail_key], map: "uq_ai_playground_guardrails_app_key")
  @@index([app_id, sort_order], map: "idx_ai_playground_guardrails_app_sort")
}

model ai_playground_metric_items {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  app_id        String    @db.Uuid
  metric_key    String    @db.VarChar(80)
  label         String    @db.VarChar(120)
  value         String    @db.VarChar(120)
  delta         String    @db.VarChar(120)
  trend         String    @db.VarChar(20)
  positive_when String    @db.VarChar(20)
  sort_order    Int?      @default(0)
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
  updated_at    DateTime? @default(now()) @db.Timestamptz(6)
  apps          apps      @relation(fields: [app_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([app_id, metric_key], map: "uq_ai_playground_metrics_app_key")
  @@index([app_id, sort_order], map: "idx_ai_playground_metrics_app_sort")
}

model ai_playground_sessions {
  id                   String                            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  app_id               String                            @db.Uuid
  selected_model_id    String?                           @db.Uuid
  selected_strategy_id String?                           @db.Uuid
  selected_persona_id  String?                           @db.Uuid
  status               String?                           @default("active") @db.VarChar(20)
  created_at           DateTime?                         @default(now()) @db.Timestamptz(6)
  updated_at           DateTime?                         @default(now()) @db.Timestamptz(6)
  apps                 apps                              @relation(fields: [app_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  selected_model       ai_playground_models?             @relation("playground_selected_model", fields: [selected_model_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  selected_strategy    ai_playground_routing_strategies? @relation("playground_selected_strategy", fields: [selected_strategy_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  selected_persona     ai_playground_personas?           @relation("playground_selected_persona", fields: [selected_persona_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  turns                ai_playground_turns[]

  @@index([app_id, updated_at], map: "idx_ai_playground_sessions_app_updated")
  @@index([app_id, status], map: "idx_ai_playground_sessions_app_status")
}

model ai_playground_turns {
  id         String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  app_id     String                 @db.Uuid
  session_id String                 @db.Uuid
  role       String                 @db.VarChar(20)
  content    String
  model_name String?                @db.VarChar(160)
  tokens_in  Int?
  tokens_out Int?
  latency_ms Int?
  cost_usd   Decimal?               @db.Decimal(12, 6)
  sort_order Int                    @default(0)
  created_at DateTime?              @default(now()) @db.Timestamptz(6)
  apps       apps                   @relation(fields: [app_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sessions   ai_playground_sessions @relation(fields: [session_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([session_id, sort_order], map: "idx_ai_playground_turns_session_sort")
  @@index([app_id, created_at], map: "idx_ai_playground_turns_app_created")
}

model top_up_packages {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique @db.VarChar(100)
  price_usd   Decimal  @db.Decimal(10, 2)
  credits     Decimal  @db.Decimal(10, 2)
  description String?
  is_active   Boolean? @default(true)
  sort_order  Int?     @default(0)

  @@index([is_active], map: "idx_top_up_packages_active")
  @@index([sort_order], map: "idx_top_up_packages_order")
}

model platform_settings {
  key        String    @id @db.VarChar(100)
  value      String
  updated_by String?   @db.Uuid
  updated_at DateTime? @default(now()) @db.Timestamptz(6)

  @@index([key], map: "idx_platform_settings_key")
}

model app_categories {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String       @db.VarChar(100)
  slug        String       @unique @db.VarChar(100)
  description String?
  icon        String?      @db.VarChar(50)
  sort_order  Int?         @default(0)
  created_at  DateTime?    @default(now()) @db.Timestamptz(6)
  updated_at  DateTime?    @default(now()) @db.Timestamptz(6)
  app_center  app_center[]
}

model app_center {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String              @db.VarChar(255)
  slug              String              @unique @db.VarChar(255)
  author            String              @default("ScaleChat") @db.VarChar(255)
  caption           String
  description       String?
  category_id       String?             @db.Uuid
  icon_url          String?
