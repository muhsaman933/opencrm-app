{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["ES2022"],
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"declaration": true,
		"declarationMap": true,
		"composite": true,
		"noEmit": true,
		"types": ["bun-types"]
	},
	"references": [{ "path": "./apps/backend" }, { "path": "./apps/frontend" }],
	"exclude": ["node_modules", "dist", ".turbo"]
}
